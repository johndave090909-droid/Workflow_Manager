rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Screenshots folder: open read/write so GitHub Actions can upload PNGs
    match /screenshots/{allPaths=**} {
      allow read, write: if true;
    }

    // Worker portal: allow unauthenticated schedule image uploads
    match /shiftflow-schedules/{file} {
      allow read, write: if true;
    }

    // CCBL thumbnails are public (small resized versions, safe to expose)
    match /CCBL/thumbs/{file} {
      allow read: if true;
    }

    // CCBL background video is public (used on the public landing page)
    match /Whisk_gto3azmmbjm4e2yy0yy3ytytuwzlrtllhzmk1sm.mp4 {
      allow read: if true;
    }

    // Directory gallery is public (used on the Taste Polynesia page)
    match /DirectoryGallery/{file} {
      allow read: if true;
    }

    // CCBL root-level files are public (videos used on Taste Polynesia page)
    match /CCBL/{file} {
      allow read: if true;
    }

    // Everything else requires a signed-in user
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
